/**
 * @fileoverview Firestore Security Rules for VesselTrack application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles
 * and assumes administrative control over vessel and tracking event data.
 *
 * Data Structure:
 * - /users/{userId}/profile: User-specific profile information.
 * - /vessels/{vesselId}: Information about individual vessels.
 * - /vessels/{vesselId}/tracking_events/{trackingEventId}: Tracking events associated with vessels.
 *
 * Key Security Decisions:
 * - User profiles are strictly private to the owning user.
 * - Vessel and tracking event management is assumed to be handled by authorized personnel (e.g., admins).
 * - Data validation during write operations is limited to authorization-critical fields.
 *
 * Denormalization for Authorization:
 * - No denormalization is necessary as user profiles are accessed via path-based ownership,
 *   and vessel/tracking event data is assumed to be managed by admins.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}/profile
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (create) User with ID 'user456' cannot create a profile under 'user123'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId}/profile {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allows a user to read their own profile.
      allow get: if isOwner(userId);

      // Allows a user to list profiles (disabled - not appropriate for user profiles).
      allow list: if false;

      // Allows a user to create their own profile if the userId matches their auth id.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Allows a user to update their own profile if the userId matches their auth id and the document exists.
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      // Allows a user to delete their own profile if the userId matches their auth id and the document exists.
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to vessel documents. Assumes admin-level control.
     * @path /vessels/{vesselId}
     * @allow (get) Anyone can read vessel information.
     * @allow (list) Anyone can list vessels.
     * @allow (create) Only authenticated users can create vessels.
     * @allow (update) Only authenticated users can update vessels.
     * @allow (delete) Only authenticated users can delete vessels.
     * @deny (create) Unauthenticated users cannot create vessels.
     * @principle Enforces admin-level control for vessel data.
     */
    match /vessels/{vesselId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Allows anyone to read vessel information.
      allow get: if true;

      // Allows anyone to list vessels.
      allow list: if true;

      // Allows only authenticated users to create vessels.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow create: if isSignedIn();

      // Allows only authenticated users to update vessels.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow update: if isSignedIn() && resource != null;

      // Allows only authenticated users to delete vessels.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to tracking event documents for vessels. Assumes admin-level control.
     * @path /vessels/{vesselId}/tracking_events/{trackingEventId}
     * @allow (get) Anyone can read tracking event information.
     * @allow (list) Anyone can list tracking events for a vessel.
     * @allow (create) Only authenticated users can create tracking events.
     * @allow (update) Only authenticated users can update tracking events.
     * @allow (delete) Only authenticated users can delete tracking events.
     * @deny (create) Unauthenticated users cannot create tracking events.
     * @principle Enforces admin-level control for tracking event data.
     */
    match /vessels/{vesselId}/tracking_events/{trackingEventId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Allows anyone to read tracking event information.
      allow get: if true;

      // Allows anyone to list tracking events for a vessel.
      allow list: if true;

      // Allows only authenticated users to create tracking events.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow create: if isSignedIn();

      // Allows only authenticated users to update tracking events.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow update: if isSignedIn() && resource != null;

      // Allows only authenticated users to delete tracking events.
      // TODO: Add a more specific authorization check (e.g., admin role).
      allow delete: if isSignedIn() && resource != null;
    }
  }
}
// Trigger re-deployment to enable auth providers.
// This comment is added to force a backend update.
